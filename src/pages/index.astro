---
import CompanyLayout from '../layouts/CompanyLayout.astro';

const pageTitle = 'Cold Forge Works LLC';
const pageDescription =
    'Cold Forge Works LLC builds practical software tools, mobile apps, and web platforms for coordination, search, and community workflows.';
---

<CompanyLayout title={pageTitle} description={pageDescription}>
    <section class="pb-16 sm:pb-20" aria-labelledby="hero-heading">
        <p class="section-label mb-4">Software development</p>
        <h1 id="hero-heading" class="mb-5">Cold Forge Works LLC</h1>
        <p class="mb-4 text-xl font-medium text-gray-200 sm:text-2xl">
            Software Tools, Mobile Apps, and Web Platforms
        </p>
        <p class="max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
            We build practical technology for real-world coordination, search, data workflows, and community
            platforms — focused on tools people can use day to day.
        </p>
    </section>

    <section id="about" class="border-t border-border py-16 sm:py-20" aria-labelledby="about-heading">
        <p class="section-label mb-4">About</p>
        <h2 id="about-heading" class="mb-6">About</h2>
        <div class="space-y-4 text-base leading-relaxed text-gray-300">
            <p>
                Cold Forge Works LLC builds practical software tools, mobile apps, and web platforms. We focus on
                practical products with clear real-world use cases.
            </p>
            <p>Our work spans several areas:</p>
            <ul class="list-inside list-disc space-y-2 text-muted">
                <li>Location and search workflows</li>
                <li>Community platforms</li>
                <li>Data-driven utilities</li>
                <li>Lightweight business tools</li>
            </ul>
        </div>
    </section>

    <section id="projects" class="border-t border-border py-16 sm:py-20" aria-labelledby="projects-heading">
        <p class="section-label mb-4">Work in progress</p>
        <h2 id="projects-heading" class="mb-8">Current Projects</h2>
        <div class="grid gap-6 sm:gap-7">
            <article class="project-card">
                <h3>BackDoor Map</h3>
                <p class="mt-3 text-sm font-medium text-accent">Mobile app · In development</p>
                <p class="mt-4 leading-relaxed text-gray-300">
                    A mobile app for crowdsourced reported freight and service entrance pins. It helps users identify
                    which side of a building others have reported as the service entrance — useful context when
                    coordinating deliveries or site visits.
                </p>
                <p class="disclaimer">
                    BackDoor Map is not parking guidance, access guidance, or instructions for entering restricted
                    areas. Pins reflect reported information only and should be verified on site.
                </p>
            </article>

            <article class="project-card">
                <h3>reviveme.gg</h3>
                <p class="mt-3 text-sm font-medium text-accent">Web platform · In development</p>
                <p class="mt-4 leading-relaxed text-gray-300">
                    A community platform for older games, focused on follows, looking-for-group activity, events,
                    and reminders so players can find others and stay engaged.
                </p>
            </article>

            <article class="project-card">
                <h3>ForgeScout</h3>
                <p class="mt-3 text-sm font-medium text-muted">Internal utility · In development</p>
                <p class="mt-4 leading-relaxed text-gray-300">
                    Lightweight resale and market-analysis tooling used internally to explore pricing signals and
                    listing context. It supports product research but is not the primary focus of the company.
                </p>
            </article>
        </div>
    </section>

    <section id="contact" class="border-t border-border py-16 sm:py-20" aria-labelledby="contact-heading">
        <p class="section-label mb-4">Get in touch</p>
        <h2 id="contact-heading" class="mb-6">Contact</h2>
        <dl class="space-y-4 text-base">
            <div>
                <dt class="section-label mb-1">Email</dt>
                <dd>
                    <a href="mailto:support@coldforgeworks.com" class="font-medium">support@coldforgeworks.com</a>
                </dd>
            </div>
            <div>
                <dt class="section-label mb-1">Location</dt>
                <dd class="text-gray-300">Port Washington, NY</dd>
            </div>
        </dl>
    </section>
</CompanyLayout>
